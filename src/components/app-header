    height: 32,
    borderRadius: 16,
    backgroundColor: PRIMARY,
    alignItems: 'center',
    justifyContent: 'center',
  },

  // Menu
  menuOverlay: {
    flex: 1,
    backgroundColor: 'rgba(0,0,0,0.35)',
  },
  menuContainer: {
    width: '78%',
    height: '100%',
    backgroundColor: PRIMARY,
    paddingHorizontal: 22,
    justifyContent: 'space-between',
  },
  menuTopRow: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingTop: 8,
  },
  menuBrand: {
    color: '#fff',
    fontSize: 16,
  },
  menuList: {
    flex: 1,
    justifyContent: 'center',
    gap: 22,
  },
  menuItem: {
    flexDirection: 'row',
