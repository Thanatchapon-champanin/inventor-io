import { Ionicons } from '@expo/vector-icons';
import { useLocalSearchParams } from 'expo-router';
import { ScrollView, StyleSheet, View, Image } from 'react-native';

import { AppHeader } from '../../components/app-header';
import { ThemedText } from '../../components/themed-text';
import { ThemedView } from '../../components/themed-view';
import { BORDER, CARD, MUTED, PRIMARY, RADIUS, SUCCESS } from '../../constants/inventor-theme';

// Import ข้อมูลสินค้าจากไฟล์ JSON นอกสุดของโปรเจกต์
import productsData from '../../../products.json';

function InfoRow({ label, value }: { label: string; value: string }) {
  return (
    <View style={styles.infoRow}>
      <ThemedText type="small" style={styles.infoLabel}>
        {label}
      </ThemedText>
      <ThemedText type="small" style={styles.infoValue}>
        {value}
      </ThemedText>
    </View>
  );
}

export default function ProductDetailsScreen() {
  const { id } = useLocalSearchParams<{ id: string }>();

  // ค้นหาสินค้าที่มี ID ตรงกับข้อมูลที่กดนำทางเข้ามา
  const PRODUCT = productsData.find((item) => item.id === id);

  // ป้องกันแอปค้างในกรณีที่ค้นหาข้อมูลสินค้าตาม ID นั้นไม่พบ
  if (!PRODUCT) {
    return (
      <ThemedView style={styles.container}>
        <AppHeader title="Products" />
        <View style={styles.notFoundWrap}>
          <Ionicons name="alert-circle-outline" size={48} color={MUTED} />
          <ThemedText style={{ marginTop: 8 }}>Product not found</ThemedText>
        </View>
      </ThemedView>
    );
  }

  // จำลองข้อมูลร้านค้าที่พร้อมจำหน่าย (อ้างอิงจากจานวนสาขาใน JSON)
  const mockStores = [
    { name: 'Manchester, UK', available: true },
    { name: 'Yorkshire, UK', available: true },
    { name: 'Hull, UK', available: PRODUCT.location_count > 3 },
    { name: 'Leicester, UK', available: PRODUCT.stock > 5 },
  ];

  return (
    <ThemedView style={styles.container}>
      <AppHeader title="Products" />

      <ScrollView showsVerticalScrollIndicator={false} contentContainerStyle={styles.scrollContent}>
        <View style={styles.card}>
          
          {/* ส่วนแสดงรูปภาพสินค้าจริงที่ดึงมาจาก URL ใน JSON */}
          <View style={styles.imageContainer}>
            <Image 
              source={{ uri: PRODUCT.image_url }} 
              style={styles.productImage}
              resizeMode="cover"
            />
          </View>

          <ThemedText type="title" style={styles.name}>
            {PRODUCT.name}
          </ThemedText>
          <ThemedText type="small" style={[
            styles.brand, 
            { color: PRODUCT.badge_status === 'Active' ? SUCCESS : '#E14848' }
          ]}>
            Status: {PRODUCT.badge_status}
          </ThemedText>

          <View style={styles.infoBlock}>
            <InfoRow label="Category" value={PRODUCT.category} />
            <InfoRow label="Stock Available" value={`${PRODUCT.stock} units`} />
            <InfoRow label="Current Status" value={PRODUCT.stock_text} />
            <InfoRow label="Available Stores" value={PRODUCT.location_text} />
          </View>

          {/* QR Code ส่วนแสดงข้อมูลจำลองตามรหัสสินค้า */}
          <View style={styles.qrWrap}>
            <Ionicons name="qr-code" size={96} color="#1A1A2E" />
            <ThemedText type="small" style={{ color: MUTED, marginTop: 4 }}>Product ID: {PRODUCT.id}</ThemedText>
          </View>

          <ThemedText type="defaultSemiBold" style={styles.storeTitle}>
            Store availability
          </ThemedText>
          {mockStores.map((store, i) => (
            <View
              key={store.name}
              style={[
                styles.storeRow,
                i === mockStores.length - 1 && { borderBottomWidth: 0 },
              ]}>
              <ThemedText type="small">{store.name}</ThemedText>
              <Ionicons
                name={store.available ? 'checkmark-circle' : 'close-circle'}
                size={18}
                color={store.available ? SUCCESS : '#E14848'}
              />
            </View>
          ))}

          <ThemedText type="small" style={styles.updated}>
            Last updated Today
          </ThemedText>
        </View>
      </ScrollView>
    </ThemedView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1 },
  scrollContent: {
    paddingHorizontal: 20,
    paddingBottom: 32,
  },
  card: {
    backgroundColor: CARD,
    borderRadius: RADIUS,
    padding: 16,
    borderWidth: 1,
    borderColor: BORDER,
  },
  imageContainer: {
    width: '100%',
    height: 200,
    borderRadius: 14,
    overflow: 'hidden',
    backgroundColor: '#F5F5F5',
    marginBottom: 14,
  },
  productImage: {
    width: '100%',
    height: '100%',
  },
  name: { fontSize: 18 },
  brand: { marginTop: 2, marginBottom: 14, fontWeight: '600' },

  infoBlock: {
    borderTopWidth: 1,
    borderTopColor: BORDER,
    paddingTop: 10,
    marginBottom: 14,
  },
  infoRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    paddingVertical: 6,
  },
  infoLabel: { color: MUTED },
  infoValue: { fontWeight: '600' },

  qrWrap: {
    alignItems: 'center',
    paddingVertical: 16,
  },

  storeTitle: { marginBottom: 6 },
  storeRow: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingVertical: 8,
    borderBottomWidth: 1,
    borderBottomColor: BORDER,
  },
  updated: {
    color: MUTED,
    marginTop: 12,
    textAlign: 'center',
  },
  notFoundWrap: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center',
  }
});